@inherits LayoutComponentBase
@inject WebUi.Services.ErrorDialogService ErrorDialog

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
        </div>

        <article class="content px-4">
            <ErrorBoundary>
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent Context="ex">
                    <div style="padding: 24px; text-align: center;">
                        <p style="font-size: 18px; color: #c41e3a; margin-bottom: 16px;">
                            เกิดข้อผิดพลาดที่ไม่คาดคิด
                        </p>
                        <p style="color: #666; margin-bottom: 16px;">@ex.Message</p>
                        <AntDesign.Button Type="@AntDesign.ButtonType.Primary" OnClick="@(() => ErrorDialog.ShowAsync("รายละเอียดข้อผิดพลาด", ex))">
                            ดูรายละเอียด
                        </AntDesign.Button>
                    </div>
                </ErrorContent>
            </ErrorBoundary>
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
