@inherits LayoutComponentBase
@inject WebUi.Services.ErrorDialogService ErrorDialog

<div class="layout-shell">
    <aside class="sidebar">
        <NavMenu />
    </aside>

    <main class="main">
        <header class="topbar">
            <div class="topbar-search">
                <span class="material-symbols-outlined topbar-search-icon">search</span>
                <input type="text" placeholder="ค้นหาเมนูหรือคำสั่ง..." aria-label="ค้นหา" />
            </div>
            <div class="topbar-actions">
                <button class="icon-button" type="button" aria-label="การแจ้งเตือน">
                    <span class="material-symbols-outlined">notifications</span>
                </button>
                <button class="icon-button" type="button" aria-label="ช่วยเหลือ">
                    <span class="material-symbols-outlined">help</span>
                </button>
                <div class="topbar-divider"></div>
                <div class="topbar-user">
                    <div class="topbar-user-text">
                        <p class="topbar-user-name">ผู้ใช้งาน</p>
                    </div>
                    <div class="topbar-avatar">US</div>
                </div>
            </div>
        </header>

        <article class="content">
            <ErrorBoundary>
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent Context="ex">
                    <div style="padding: 24px; text-align: center;">
                        <p style="font-size: 18px; color: #c41e3a; margin-bottom: 16px;">
                            เกิดข้อผิดพลาดที่ไม่คาดคิด
                        </p>
                        <p style="color: #666; margin-bottom: 16px;">@ex.Message</p>
                        <AntDesign.Button Type="@AntDesign.ButtonType.Primary" OnClick="@(() => ErrorDialog.ShowAsync("รายละเอียดข้อผิดพลาด", ex))">
                            ดูรายละเอียด
                        </AntDesign.Button>
                    </div>
                </ErrorContent>
            </ErrorBoundary>
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
